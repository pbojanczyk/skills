{
  "name": "mofang-records",
  "version": "3.0.0",
  "description": "魔方网表记录管理 Skill，支持通过自然语言对魔方网表中的记录进行查询、创建、修改和删除操作。",
  "author": "magicscape",
  "requiredTools": ["exec"],
  "tags": ["mofang", "no-code", "records", "crud", "rest-api", "cli"],
  "config": {
    "BASE_URL": {
      "type": "string",
      "description": "魔方网表服务器地址，例如 https://example.mf999.com",
      "default": ""
    },
    "USERNAME": {
      "type": "string",
      "description": "魔方网表登录用户名",
      "default": ""
    },
    "PASSWORD": {
      "type": "string",
      "description": "魔方网表登录密码",
      "default": ""
    }
  },
  "hooks": {
    "onInstall": "npm install && npm run build",
    "onActivate": "node cli.mjs --help"
  }
}
